        <!-- Phase 3: 出力 -->
        <mxCell id="evidence" parent="1" style="whiteSpace=wrap;strokeWidth=2;" value="エビデンス画像保存（evidence/タイムスタンプ/）&#xa;読み取り結果Excel出力" vertex="1">
          <mxGeometry height="60" width="320" x="140" y="950" as="geometry" />
