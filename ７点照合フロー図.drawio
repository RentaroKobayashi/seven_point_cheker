        </mxCell>

        <!-- Phase 1: カタログ抽出 -->
        <mxCell id="catalog_extract" parent="1" style="whiteSpace=wrap;strokeWidth=2;fillColor=#d5e8d4;strokeColor=#82b366;" value="【Phase 1】カタログ抽出（並列3ワーカー）&#xa;カタログ用プロンプト（項目リストから生成）&#xa;→ Agentic Vision で値抽出&#xa;→ BBox座標取得" vertex="1">
          <mxGeometry height="100" width="280" x="390" y="470" as="geometry" />
        </mxCell>

        <!-- カタログ値統合 -->
        <mxCell id="catalog_merge" parent="1" style="whiteSpace=wrap;strokeWidth=2;fillColor=#d5e8d4;strokeColor=#82b366;" value="カタログ値を統合&#xa;→ 技術資料読み取りのヒントに使う" vertex="1">
          <mxGeometry height="60" width="280" x="390" y="590" as="geometry" />
        </mxCell>

        <!-- Phase 2: 技術資料抽出 -->
        <mxCell id="doc_extract" parent="1" style="whiteSpace=wrap;strokeWidth=2;fillColor=#d5e8d4;strokeColor=#82b366;" value="【Phase 2】技術資料を並列抽出（3ワーカー）&#xa;各画像ごとに:&#xa;① カタログ値をヒントに埋め込んだ検証プロンプト生成&#xa;② Agentic Vision で値抽出（書き方は違えど&#xa;　 意味・数値が同じ情報を探す）&#xa;③ BBox座標取得 → 画像にBBox描画" vertex="1">
          <mxGeometry height="130" width="320" x="140" y="700" as="geometry" />
        </mxCell>

        <!-- 文書マージ -->
        <mxCell id="merge" parent="1" style="whiteSpace=wrap;strokeWidth=2;" value="同一文書種別の複数ページを1エントリに統合&#xa;（コンフリクト時はカタログヒントで解決）" vertex="1">
          <mxGeometry height="60" width="320" x="140" y="860" as="geometry" />
