        </mxCell>

        <!-- Step 3: ファイル名分類 -->
        <mxCell id="classify" parent="1" style="whiteSpace=wrap;strokeWidth=2;fillColor=#fff2cc;strokeColor=#d6b656;" value="ファイル名で画像を6カテゴリに分類&#xa;（カタログ/組立図/承認図/器具銘板/取扱説明書/外装ラベル）&#xa;※ API呼出なし" vertex="1">
