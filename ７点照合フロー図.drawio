        <!-- Step 1: アップロード -->
        <mxCell id="upload" parent="1" style="whiteSpace=wrap;strokeWidth=2;" value="項目リスト（CSV/Excel）と&#xa;資料画像（PNG/JPEG/PDF）をアップロード&#xa;→「抽出実行」ボタン" vertex="1">
          <mxGeometry height="80" width="280" x="160" y="80" as="geometry" />
